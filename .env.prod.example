APP_NAME=Flow-POS Backend
ENVIRONMENT=production
SECRET_KEY=replace-with-a-random-secret-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=60
DATABASE_URL=postgresql+psycopg://flowpos:replace-with-db-password@db:5432/flowpos
REDIS_URL=redis://redis:6379/0
AUTO_CREATE_TABLES=false
ALLOW_SQLITE_IN_PRODUCTION=false
BACKEND_CORS_ORIGINS=https://pos.example.com
DOCS_ENABLED=false
